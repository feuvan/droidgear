# Auto-detect text files and normalize line endings to LF
* text=auto

# Rust / Cargo files - force LF
*.rs text eol=lf
Cargo.toml text eol=lf
Cargo.lock text eol=lf

# JavaScript / TypeScript / npm files - force LF
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Binary files - keep as-is
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.icns binary
*.ico binary
